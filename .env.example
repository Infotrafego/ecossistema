# ═══════════════════════════════════════════════════════════════
# Ecossistema Infotráfego · variáveis de ambiente
# ═══════════════════════════════════════════════════════════════
# Local: copie pra .env.local e preencha.
# Produção: veja onde cada var entra no fluxo de deploy abaixo.
#
#   ┌─────────────────────────────────────────────────────────────┐
#   │ BUILD-TIME (NEXT_PUBLIC_*) → embutidas no bundle no build.   │
#   │   → vão como GitHub Secrets, usadas no .github/workflows.    │
#   │   → são PÚBLICAS (vão pro browser). A anon key é pública     │
#   │     por design; o RLS é quem protege os dados.               │
#   ├─────────────────────────────────────────────────────────────┤
#   │ RUNTIME (resto) → segredos de servidor, NUNCA no bundle.     │
#   │   → preenchidas no Portainer (Environment variables).        │
#   └─────────────────────────────────────────────────────────────┘

# ═══ Supabase · BUILD-TIME (públicas) ═══
# Projeto "Infotráfego" · ref jcserimdehwyxghdgmgj · schema infotrafego_ecossistema
NEXT_PUBLIC_SUPABASE_URL=https://jcserimdehwyxghdgmgj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ═══ App · BUILD-TIME (pública) ═══
# Local: http://localhost:3000 · Prod: https://ecossistema.servidordainfotrafego.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══ Supabase · RUNTIME (segredo) ═══
# Dashboard → Settings → API → service_role (secret). NUNCA expor ao client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ═══ Claude API · RUNTIME (segredo) ═══
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ═══ Meta Marketing API · RUNTIME (segredo) ═══
# https://developers.facebook.com/apps/[SEU_APP]/dashboard
# System User token (longa duração) recomendado pra produção.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ═══ ClickUp · RUNTIME (segredo · opcional na Fase 2) ═══
CLICKUP_API_TOKEN=
